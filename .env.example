TZ=America/Asuncion

# Local runtime
CENTINELA_DEFAULT_COUNTRY=py
# Leave blank to use a non-sync local runtime folder:
# Windows default: %LOCALAPPDATA%\Centinela\data
# Cross-platform fallback: ~/.centinela/data
CENTINELA_OUTPUT_DIR=

# Optional PostgreSQL target
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=centinela
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=
POSTGRES_SCHEMA=centinela

# Optional VPS access notes
VPS_HOST=
VPS_USER=
VPS_PASSWORD=

# Optional authenticated OpenSanctions/Yente matching
OPENSANCTIONS_API_BASE_URL=https://api.opensanctions.org
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_MATCH_DATASET=default
OPENSANCTIONS_MATCH_ALGORITHM=logic-v2
OPENSANCTIONS_MATCH_THRESHOLD=0.7
OPENSANCTIONS_MATCH_RESULT_LIMIT=5
YENTE_BASE_URL=
YENTE_API_KEY=
